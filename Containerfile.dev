# --- base: Rust + System-Dependencies + Cargo-Tools ---
FROM docker.io/library/rust:1.88-slim-bookworm AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libclang-dev \
    libpipewire-0.3-dev \
    libspa-0.2-dev \
    libdbus-1-dev \
    libssl-dev \
    libvulkan-dev \
    mesa-vulkan-drivers \
    libwebkit2gtk-4.1-dev \
    libgtk-3-dev \
    libayatana-appindicator3-dev \
    libxdo-dev \
    && rm -rf /var/lib/apt/lists/* \
    && cargo install --locked cargo-auditable cargo-audit

WORKDIR /build

# --- build: Kompilieren ---
FROM base AS build

COPY Cargo.toml ./
COPY Cargo.lock* ./
COPY crates/screenchaser-config/Cargo.toml crates/screenchaser-config/Cargo.toml
COPY crates/screenchaser-capture/Cargo.toml crates/screenchaser-capture/Cargo.toml
COPY crates/screenchaser-gpu/Cargo.toml crates/screenchaser-gpu/Cargo.toml
COPY crates/screenchaser-wled/Cargo.toml crates/screenchaser-wled/Cargo.toml
COPY crates/screenchaser-daemon/Cargo.toml crates/screenchaser-daemon/Cargo.toml

RUN for crate in crates/*/; do \
        mkdir -p "$crate/src" && echo '' > "$crate/src/lib.rs"; \
    done \
    && echo 'fn main() {}' > crates/screenchaser-daemon/src/main.rs \
    && cargo auditable build --release 2>/dev/null || true \
    && rm -rf crates/*/src

COPY crates/ crates/
RUN cargo audit \
    && cargo auditable build --release

# --- test: Test-Dependencies ---
FROM build AS test
